    "Find your files naturally. Just type what you're looking for, like 'Photos of last week' or 'Work documents from 2024'." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Find your files naturally. Just type what you're looking for, like 'Photos of last week' or 'Work documents from 2024'."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Encuentre sus archivos de forma natural. Simplemente escriba lo que está buscando, como 'Fotos de la semana pasada' o 'Documentos de trabajo de 2024'."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自然な言葉でファイルを探せます。「先週の写真」や「2024年の仕事の書類」のように入力するだけです。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自然地搜索您的文件。只需输入您要查找的内容，例如“上周的照片”或“2024 年的工作文档”。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自然地搜尋您的檔案。只需輸入您要查找的内容，例如「上週的照片」或「2024 年的工作文檔」。"
          }
        }
      }
    },
