    "AI can make mistakes. Always verify results before performing critical file operations." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI can make mistakes. Always verify results before performing critical file operations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La IA puede cometer errores. Verifique siempre los resultados antes de realizar operaciones críticas con archivos."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AIは間違いを犯す可能性があります。重要なファイル操作を行う前に、必ず結果を確認してください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI 可能会犯错。在执行关键文件操作之前，请务必核实结果。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI 可能會犯錯。在執行關鍵檔案操作之前，請務必核實結果。"
          }
        }
      }
    },
