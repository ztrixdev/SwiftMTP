    "In API mode, you are responsible for any usage costs from your AI provider." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In API mode, you are responsible for any usage costs from your AI provider."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En el modo API, usted es responsable de los costos de uso de su proveedor de IA."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APIモードでは、AIプロバイダーからの使用コストはユーザーの責任となります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 API 模式下，您需要承担 AI 提供商产生的任何使用费用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 API 模式下，您需要承擔 AI 提供商產生的任何使用費用。"
          }
        }
      }
    },
    "In API mode, your item metadata such as names, types, and sizes will be sent to the provider. The contents of your files are never uploaded or shared." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In API mode, your item metadata such as names, types, and sizes will be sent to the provider. The contents of your files will never be uploaded or shared."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En el modo API, los metadatos de sus elementos, como nombres, tipos y tamaños, se enviarán al proveedor. El contenido de sus archivos nunca se carga ni se comparte."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "APIモードでは、名前、種類、サイズなどのアイテム의メタデータがプロバイダーに送信されます。ファイルの内容がアップロードされたり共有されたりすることはありません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 API 模式下，您的项目元数据（如名称、类型和大小）将发送给提供商。您的文件内容永远不会被上传或共享。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 API 模式下，您的項目元資料（如名稱、類型和大小）將發送給提供商。您的檔案內容永遠不會被上傳或共享。"
          }
        }
      }
    },
