    "When enabled, double-clicking a file exports it to a local cache (if not already cached) and opens it with the default application." : {
      "comment" : "Tooltip for double-click to open file setting",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, double-clicking a file exports it to a local cache (if not already cached) and opens it with the default application."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando está habilitado, al hacer doble clic en un archivo se exporta en una caché local (si aún no está en caché) y se abre con la aplicación predeterminada."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、ファイルをダブルクリックしたときにローカルキャッシュにエクスポートし（キャッシュされていない場合）、デフォルトのアプリケーションで開きます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开启后，双击文件将导出到本地缓存（如果尚未缓存）并使用默认应用打开。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開啟後，雙擊檔案將導出到本地快取（如果尚未快取）並使用預設應用程式開啟。"
          }
        }
      }
    },
